app:
  # Generate a long random string for production. Empty value only logs a warning.
  secret_key: ""
  algorithm: "HS256"
  access_token_expire_minutes: 1440

database:
  # charset=utf8mb4 is REQUIRED — without it pymysql defaults to latin1 and all
  # Chinese text (table comments, project names, messages) is stored as mojibake.
  url: "mysql+pymysql://YOUR_USER:YOUR_PASSWORD@localhost:3306/ddh_agent?charset=utf8mb4"

llm:
  provider: claude  # or "qwen"
  claude:
    api_key: ""
    model: claude-sonnet-4-6
  qwen:
    api_key: ""
    model: qwen-max

files:
  projects_dir: "./projects"
